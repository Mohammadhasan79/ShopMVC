@model IEnumerable<EFLearn.Models.Product>

@{
    ViewData["Title"] = "Index";
}

<h1>محصولات</h1>

<ul>
    <li><a asp-action="Create">افزودن</a></li>
        <li><a asp-action="Filter" asp-controller="Products">فیلتر کردن</a></li>
    <li><a asp-action="Sort" asp-controller="Products">مرتب کردن</a></li>
    <li><a asp-action="MyProduct" asp-controller="Products">محصولات من</a></li>
</ul>
<table class="table">
    <thead>
        <tr>
            <th>
                ID
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                Category
            </th>
            <th>
                Moddify
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @item.Category?.Name
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
            @* <td>
                <select class="dropdown" asp-items="@ViewBag.CatList"></select>
            </td> *@
        </tr>
}
    </tbody>
</table>
